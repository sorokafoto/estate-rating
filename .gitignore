# PII: локальные выгрузки и legacy private/
data/
private/

# Структура data/ в репозитории (без PII)
!data/manifest.example.json
!data/**/.gitkeep

# Табличные выгрузки вне data/ (на всякий случай)
*.xlsx
*.xls
*.csv

# Ключи / секреты
*.pem
*.key
.env
.env.*
service-account*.json
credentials*.json

# Node
node_modules/
npm-debug.log*

# Production bundle (npm run publish)
publish/
